{
  "name": "react-native-modalx",
  "version": "0.1.0",
  "description": "A modern, Reanimated-first, fully-customizable Modal for React Native — drop-in replacement for react-native-modal with imperative API, gesture v2 swipes, and built-in stacking.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.ts",
  "types": "lib/typescript/commonjs/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "CHANGELOG.md",
    "!src/__tests__",
    "!**/*.test.ts",
    "!**/*.test.tsx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kuraydev/react-native-modalx.git"
  },
  "author": "FreakyCoder <kurayogun@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/kuraydev/react-native-modalx#readme",
  "bugs": {
    "url": "https://github.com/kuraydev/react-native-modalx/issues"
  },
  "keywords": [
    "react-native",
    "modal",
    "react-native-modal",
    "modalx",
    "reanimated",
    "gesture-handler",
    "bottom-sheet",
    "dialog",
    "swipe",
    "animated",
    "typescript"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:ci": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "prettier": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "prettier:ci": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run typecheck && npm run lint:ci && npm test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.3.0",
    "react-native": ">=0.78.0",
    "react-native-gesture-handler": ">=2.16.0",
    "react-native-reanimated": ">=3.10.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@react-native/babel-preset": "^0.78.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "react": "19.0.0",
    "react-native": "0.78.0",
    "react-native-builder-bob": "^0.30.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-reanimated": "^3.16.0",
    "react-test-renderer": "19.0.0",
    "typescript": "^5.6.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native/.*|@react-native-community/.*|@testing-library|react-native-reanimated|react-native-gesture-handler)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.types.ts",
      "!src/**/index.ts",
      "!src/types/**"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json",
          "esm": true
        }
      ]
    ]
  }
}
